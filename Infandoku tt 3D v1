inline int find_room(const S11&s,RType rt,int k){
uint64_t bit=uint64_t(1)<<k;
for(uint64_t m=ROOMS_BY_TYPE[(int)rt];m;m&=m-1){int ri=__builtin_ctzll(m);if(!(s.rb[ri]&bit))return ri;}
return -1;
}
inline uint64_t get_before(const S11&s,const std::vector<Asgn>&A,const Index11&idx,int ai){
int bai=idx.order_before_asgn[ai];if(bai<0)return 0;
return s.tb[A[bai].ti]&s.cb[A[bai].ci];
}
inline bool place11(S11&s,std::vector<Asgn>&A,const Index11&idx,int ai,int k,RingQueue&rq,Dirty&dirty){
auto&a=A[ai];int ri=find_room(s,a.rtype,k);if(ri<0)return false;
uint64_t bit=uint64_t(1)<<k;
s.set_cb(a.ci,s.cb[a.ci]|bit);s.set_tb(a.ti,s.tb[a.ti]|bit);
s.set_tf(a.ti,s.tf[a.ti]|CONSEC[k]);s.set_rb(ri,s.rb[ri]|bit);
s.trail.push_rem(ai,a.rem);a.rem–;s.cache_write(ai,0);
dirty.mark_t(a.ti);dirty.mark_c(a.ci);dirty.mark_r(ri);
int d=k/NPD;uint8_t cov=s.spread_days[a.group_id];
if(!(cov&(1<<d)))s.set_spd(a.group_id,cov|(uint8_t)(1<<d));
if(a.link>=0&&A[a.link].rem>0){s.cache_invalidate(a.link);rq.push(a.link);}
uint64_t aff=bit|CONSEC[k];
while(aff){int kk=__builtin_ctzll(aff);aff&=aff-1;if(kk>=NS)break;
for(int bai:idx.wl_slot[kk])if(A[bai].rem){s.cache_invalidate(bai);rq.push(bai);}}
return true;
}

