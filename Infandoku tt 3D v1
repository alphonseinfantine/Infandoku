struct UndoRec{uint8_t kind;uint16_t i1;uint64_t old_val;int ai;};
struct Trail{
UndoRec buf[524288];int top=0;
int marks[32768];int nm=0;
void save(){marks[nm++]=top;}
void push_tb(int i,uint64_t v){buf[top++]={0,(uint16_t)i,v,0};}
void push_tf(int i,uint64_t v){buf[top++]={1,(uint16_t)i,v,0};}
void push_cb(int i,uint64_t v){buf[top++]={2,(uint16_t)i,v,0};}
void push_rem(int ai,int v)   {buf[top++]={3,0,(uint64_t)v,ai};}
void push_rb(int ri,uint64_t v){buf[top++]={4,(uint16_t)ri,v,0};}
void push_spd(int g,uint8_t v){buf[top++]={5,(uint16_t)g,(uint64_t)v,0};}
void restore(uint64_t*tb,uint64_t*tf,uint64_t*cb,
uint64_t*rb,uint8_t*spd,std::vector<Asgn>&A){
int m=marks[–nm];
while(top>m){auto&r=buf[–top];
switch(r.kind){
case 0:tb[r.i1]=r.old_val;break;case 1:tf[r.i1]=r.old_val;break;
case 2:cb[r.i1]=r.old_val;break;case 3:A[r.ai].rem=(int)r.old_val;break;
case 4:rb[r.i1]=r.old_val;break;case 5:spd[r.i1]=(uint8_t)r.old_val;break;
}
}
}
};

struct S11{
alignas(32) uint64_t tb[MT],tf[MT],cb[NC_MAX],rb[NR];
Trail trail;
alignas(64) uint8_t  domain_val[NA_MAX];
alignas(64) uint16_t domain_gen[NA_MAX];
uint16_t cur_gen=1;
uint8_t  spread_days[NA_MAX];
void init(int nc){
memset(tb,0,sizeof tb);memset(tf,0,sizeof tf);
memset(cb,0,nc*sizeof(uint64_t));memset(rb,0,sizeof rb);
trail.top=0;trail.nm=0;
memset(domain_gen,0,sizeof domain_gen);cur_gen=1;
memset(spread_days,0,sizeof spread_days);
}
void set_tb(int i,uint64_t v){trail.push_tb(i,tb[i]);tb[i]=v;}
void set_tf(int i,uint64_t v){trail.push_tf(i,tf[i]);tf[i]=v;}
void set_cb(int i,uint64_t v){trail.push_cb(i,cb[i]);cb[i]=v;}
void set_rb(int i,uint64_t v){trail.push_rb(i,rb[i]);rb[i]=v;}
void set_spd(int g,uint8_t v){trail.push_spd(g,spread_days[g]);spread_days[g]=v;}
void cache_write(int ai,uint8_t v){domain_val[ai]=v;domain_gen[ai]=cur_gen;}
void cache_invalidate(int ai){domain_gen[ai]=0;}
bool cache_valid(int ai)const{return domain_gen[ai]==cur_gen;}
void gen_bump(){cur_gen++;}void gen_restore(uint16_t g){cur_gen=g;}
};

// avs11 : v9 + DAYMAX(prof) + ORDER
inline uint64_t avs11(const S11&s,const std::vector<Teacher>&T,
const Asgn&a, uint64_t before_slots){
int ti=a.ti,ci=a.ci;
uint64_t ds=0;
for(int d=0;d<ND;d++){
if(__builtin_popcountll(s.cb[ci]&DMASK[d])>=MPD)         ds|=DMASK[d];
if(__builtin_popcountll(s.tb[ti]&DMASK[d])>=MAX_BUSY_PD) ds|=DMASK[d];
}
// [DAYMAX] : si le prof a déjà MAX_DAYS_PROF jours utilisés, bloquer les autres
{
int days_used=0;uint64_t days_ok=0;
for(int d=0;d<ND;d++) if(s.tb[ti]&DMASK[d]){days_used++;days_ok|=DMASK[d];}
if(days_used>=MAX_DAYS_PROF) ds|=~days_ok;
}
uint64_t base=(~(s.cb[ci]|s.tb[ti]|s.tf[ti]|T[ti].unav|LUNCH|ds))
&((uint64_t(1)<<NS)-1);
// [ROOMS]
uint64_t rf=0;for(uint64_t m=ROOMS_BY_TYPE[(int)a.rtype];m;m&=m-1)rf|=~s.rb[__builtin_ctzll(m)];
base&=(rf&((uint64_t(1)<<NS)-1));
// [SPREAD]
if(a.spread_min>1&&a.rem==1){
uint8_t cov=s.spread_days[a.group_id];
if(__builtin_popcount(cov)<a.spread_min){
uint64_t uncov=0;for(int d=0;d<ND;d++)if(!(cov&(1<<d)))uncov|=DMASK[d];
base&=uncov;
}
}
// [ORDER] : filtrer créneaux avant le dernier “before” placé ce jour-là
if(before_slots){
for(int d=0;d<ND;d++){
uint64_t bs=before_slots&DMASK[d];if(!bs)continue;
int last_before=63-__builtin_clzll(bs)-d*NPD;
for(int h=0;h<=last_before;h++) base&=~(uint64_t(1)<<(d*NPD+h));
}
}
return base;
}

struct Index11{
std::vector<std::vector<int>> ci_asgn,ti_asgn,wl_slot,ri_asgn,lcv_neighbors;
std::vector<int> order_before_asgn;
void build(const std::vector<Asgn>&A,const std::vector<Teacher>&T,int nt,int nc){
int na=(int)A.size();
ci_asgn.assign(nc,{});ti_asgn.assign(nt,{});
wl_slot.assign(NS,{});ri_asgn.assign(NR,{});lcv_neighbors.assign(NS,{});
order_before_asgn.assign(na,-1);
for(int ai=0;ai<na;ai++){
ci_asgn[A[ai].ci].push_back(ai);ti_asgn[A[ai].ti].push_back(ai);
for(int ri=0;ri<NR;ri++) if(RTYPE[ri]==(int)A[ai].rtype) ri_asgn[ri].push_back(ai);
}
for(int ai=0;ai<na;ai++){
if(A[ai].order_after_si<0)continue;
for(int bai:ci_asgn[A[ai].ci])
if(A[bai].si==A[ai].order_after_si){order_before_asgn[ai]=bai;break;}
}
std::vector<int>sdeg(NS,0);
for(int ai=0;ai<na;ai++){uint64_t sd=~(T[A[ai].ti].unav|LUNCH)&((uint64_t(1)<<NS)-1);
for(uint64_t t=sd;t;t&=t-1)sdeg[__builtin_ctzll(t)]++;}
for(int ai=0;ai<na;ai++){uint64_t sd=~(T[A[ai].ti].unav|LUNCH)&((uint64_t(1)<<NS)-1);
std::vector<std::pair<int,int>>sl;
for(uint64_t t=sd;t;t&=t-1){int k=__builtin_ctzll(t);sl.push_back({sdeg[k],k});}
std::sort(sl.begin(),sl.end());
int nw=std::min((int)sl.size(),K_WATCH);
for(int i=0;i<nw;i++){int k=sl[i].second;
wl_slot[k].push_back(ai);lcv_neighbors[k].push_back(ai);
uint64_t cc=CONSEC[k];while(cc){int kk=__builtin_ctzll(cc);cc&=cc-1;if(kk<NS)lcv_neighbors[kk].push_back(ai);}
}
}
for(int k=0;k<NS;k++){auto&v=lcv_neighbors[k];std::sort(v.begin(),v.end());
v.erase(std::unique(v.begin(),v.end()),v.end());}
}
};

struct RingQueue{
static const int CAP=8192;int q[CAP];int head=0,tail=0;
void clear(){head=tail=0;}bool empty()const{return head==tail;}
void push(int ai){q[tail&(CAP-1)]=ai;tail++;}int pop(){return q[head++&(CAP-1)];}
};
struct Dirty{
uint64_t tp[MT/64]={};uint64_t tc[(NC_MAX+63)/64]={};uint32_t tr=0;
void clear(){memset(tp,0,sizeof tp);memset(tc,0,sizeof tc);tr=0;}
void mark_t(int ti){tp[ti>>6]|=uint64_t(1)<<(ti&63);}
void mark_c(int ci){tc[ci>>6]|=uint64_t(1)<<(ci&63);}
void mark_r(int ri){tr|=1u<<ri;}
template<class F>void each_t(int nt,F f){
for(int w=0;w<(nt+63)/64;w++){uint64_t b=tp[w];
while(b){int r=__builtin_ctzll(b);b&=b-1;int i=w*64+r;if(i<nt)f(i);}}
}
template<class F>void each_c(int nc,F f){
for(int w=0;w<(nc+63)/64;w++){uint64_t b=tc[w];
while(b){int r=__builtin_ctzll(b);b&=b-1;int i=w*64+r;if(i<nc)f(i);}}
}
};

