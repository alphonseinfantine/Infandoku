static const int K_LCV=8;
inline void lcv_sort(int*slots,int n,S11&s,const std::vector<Teacher>&T,
const std::vector<Asgn>&A,const Index11&idx){
if(n<=1)return;g_lcv11++;
int impacts[50]={};
for(int i=0;i<n;i++){int k=slots[i];uint64_t mask=(uint64_t(1)<<k)|CONSEC[k];
int imp=0,checked=0;
for(int ai:idx.lcv_neighbors[k]){if(!A[ai].rem||checked>=K_LCV)break;
uint64_t bef=get_before(s,A,idx,ai);
uint64_t dom=avs11(s,T,A[ai],bef);
imp+=__builtin_popcountll(dom&mask);
s.cache_write(ai,(uint8_t)std::min((int)__builtin_popcountll(dom),254));
checked++;}
impacts[i]=imp;}
for(int i=1;i<n;i++){int ki=slots[i],ii=impacts[i],j=i-1;
while(j>=0&&impacts[j]>ii){slots[j+1]=slots[j];impacts[j+1]=impacts[j];j–;}
slots[j+1]=ki;impacts[j+1]=ii;}
}

int mrv11(S11&s,const std::vector<Teacher>&T,const std::vector<Asgn>&A,const Index11&idx){
int best=-1,bc=999,na=(int)A.size();
for(int ai=0;ai<na;ai++){if(!A[ai].rem)continue;
uint8_t ds;if(s.cache_valid(ai))ds=s.domain_val[ai];
else{uint64_t bef=get_before(s,A,idx,ai);uint64_t av=avs11(s,T,A[ai],bef);
int c=__builtin_popcountll(av);ds=(uint8_t)std::min(c,254);s.cache_write(ai,ds);}
if(ds==0)return-(ai+2);if(ds<(uint8_t)bc){bc=ds;best=ai;}}
return best;
}

bool solve11(S11&s,const std::vector<Teacher>&T,std::vector<Asgn>&A,const Index11&idx,int nc){
g_nodes11++;
bool all=true;for(auto&a:A)if(a.rem){all=false;break;}if(all)return true;
int bi=mrv11(s,T,A,idx);if(bi<0){g_bt11++;return false;}
uint64_t bef=get_before(s,A,idx,bi);
uint64_t av=avs11(s,T,A[bi],bef);if(!av){g_bt11++;return false;}
int slots[50],nslots=0;
for(uint64_t tmp=av;tmp;tmp&=tmp-1)slots[nslots++]=__builtin_ctzll(tmp&(-tmp));
lcv_sort(slots,nslots,s,T,A,idx);
for(int i=0;i<nslots;i++){int k=slots[i];
s.trail.save();uint16_t sg=s.cur_gen;s.gen_bump();
RingQueue rq;rq.clear();Dirty dirty;dirty.clear();
if(place11(s,A,idx,bi,k,rq,dirty))
if(prop11(s,T,A,idx,rq,dirty,nc)&&solve11(s,T,A,idx,nc))return true;
g_bt11++;s.trail.restore(s.tb,s.tf,s.cb,s.rb,s.spread_days,A);s.gen_restore(sg);}
return false;
}

bool run11(S11&s,const std::vector<Teacher>&T,std::vector<Asgn>&A,const Index11&idx,int nc){
RingQueue rq;rq.clear();Dirty dirty;dirty.clear();
for(int ti=0;ti<(int)T.size();ti++)dirty.mark_t(ti);for(int ci=0;ci<nc;ci++)dirty.mark_c(ci);
for(int ai=0;ai<(int)A.size();ai++){uint64_t bef=get_before(s,A,idx,ai);
uint64_t av=avs11(s,T,A[ai],bef);int c=__builtin_popcountll(av);
s.cache_write(ai,(uint8_t)std::min(c,254));if(c==1)rq.push(ai);}
if(!prop11(s,T,A,idx,rq,dirty,nc))return false;
return solve11(s,T,A,idx,nc);
}

// Score de qualité soft (post-solution)
struct QScore{int gaps_prof=0;int idles_class=0;};
QScore compute_quality(const S11&s,const std::vector<Teacher>&T,int nc,int nt){
QScore q;
for(int ti=0;ti<nt;ti++){
for(int d=0;d<ND;d++){uint64_t occ=s.tb[ti]&DMASK[d]&~LUNCH;
if(__builtin_popcountll(occ)<2)continue;
