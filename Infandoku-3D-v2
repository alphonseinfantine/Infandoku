// =============================================================================
// PROPAGATION 1: Flush NS queue
// =============================================================================
// Every singleton in the queue gets re-placed, triggering eliminations that
// may create new singletons. The cascade stops when the queue empties.

bool flush_ns(Grid& g, Trail& tr, NSQueue& q) {
while (!q.empty()) {
int pos = q.pop();
int x = pos/(N*N), y = (pos/N)%N, z = pos%N;
uint16_t c = g.cell[x][y][z];
if (!c) return false;
if (c & (c-1)) continue;  // no longer a singleton (can happen with duplicates)
int v = __builtin_ctz(c) + 1;
g_ns++;
if (!place(g, tr, q, x, y, z, v)) return false;
}
return true;
}

