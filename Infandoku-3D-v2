// =============================================================================
// PROPAGATION 3: 3D Triads — “pointing pairs” generalised to 3 axes
// =============================================================================
// In each line of 9, positions are grouped into 3 triads of 3 (matching block
// boundaries). If a digit exists only within one triad of a line, it can be
// eliminated from all other lines of the same block that pass through that triad.
//
// This is the 3D extension of Tdoku’s core technique.

bool triads_3d(Grid& g, Trail& tr, NSQueue& q) {
bool changed = false;

```
// --- Axis-Z triads: line (x,y,*), triads on z in [0-2],[3-5],[6-8] ---
// Confinement in triad b → eliminate from other (x',y') lines in same XY+Z-slab block.
for (int x = 0; x < N; x++) for (int y = 0; y < N; y++) {
    for (int b = 0; b < K; b++) {
        uint16_t in_triad = 0, out_triad = 0;
        for (int z = 0; z < N; z++) {
            if (z/K == b) in_triad  |= g.cell[x][y][z];
            else          out_triad |= g.cell[x][y][z];
        }
        uint16_t excl = in_triad & ~out_triad;
        if (!excl) continue;
        // Eliminate excl from other (x',y') lines sharing XY-block and Z-triad slab
        int bx = x/K, by = y/K;
        for (int dx = 0; dx < K; dx++) for (int dy = 0; dy < K; dy++) {
            int nx = bx*K+dx, ny = by*K+dy;
            if (nx == x && ny == y) continue;
            for (int z = b*K; z < (b+1)*K; z++) {
                if (g.cell[nx][ny][z] & excl) {
                    if (!elim(g, tr, q, nx, ny, z, excl)) return false;
                    g_triads++; changed = true;
                }
            }
        }
    }
}

// --- Axis-Y triads: line (x,*,z), triads on y ---
for (int x = 0; x < N; x++) for (int z = 0; z < N; z++) {
    for (int b = 0; b < K; b++) {
        uint16_t in_t = 0, out_t = 0;
        for (int y = 0; y < N; y++) {
            if (y/K == b) in_t  |= g.cell[x][y][z];
            else          out_t |= g.cell[x][y][z];
        }
        uint16_t excl = in_t & ~out_t;
        if (!excl) continue;
        int bx = x/K, bz = z/K;
        for (int dx = 0; dx < K; dx++) for (int dz = 0; dz < K; dz++) {
            int nx = bx*K+dx, nz = bz*K+dz;
            if (nx == x && nz == z) continue;
            for (int y = b*K; y < (b+1)*K; y++) {
                if (g.cell[nx][y][nz] & excl) {
                    if (!elim(g, tr, q, nx, y, nz, excl)) return false;
                    g_triads++; changed = true;
                }
            }
        }
    }
}

// --- Axis-X triads: line (*,y,z), triads on x ---
for (int y = 0; y < N; y++) for (int z = 0; z < N; z++) {
    for (int b = 0; b < K; b++) {
        uint16_t in_t = 0, out_t = 0;
        for (int x = 0; x < N; x++) {
            if (x/K == b) in_t  |= g.cell[x][y][z];
            else          out_t |= g.cell[x][y][z];
        }
        uint16_t excl = in_t & ~out_t;
        if (!excl) continue;
        int by = y/K, bz = z/K;
        for (int dy = 0; dy < K; dy++) for (int dz = 0; dz < K; dz++) {
            int ny = by*K+dy, nz = bz*K+dz;
            if (ny == y && nz == z) continue;
            for (int x = b*K; x < (b+1)*K; x++) {
                if (g.cell[x][ny][nz] & excl) {
                    if (!elim(g, tr, q, x, ny, nz, excl)) return false;
                    g_triads++; changed = true;
                }
            }
        }
    }
}

(void)changed;
return true;
```

