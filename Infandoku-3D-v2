// =============================================================================
// TRAIL — undo log for backtracking in O(delta)
// =============================================================================

struct UndoEntry { uint16_t x, y, z, old_val; };

static const int TRAIL_CAP   = 65536;
static const int MARK_CAP    = 1024;
static const int NSQUEUE_CAP = 16384;

struct Trail {
UndoEntry buf[TRAIL_CAP];
int       marks[MARK_CAP];
int       top = 0, nm = 0;

```
void save()                          { marks[nm++] = top; }
void push(int x,int y,int z,uint16_t v) {
    buf[top++] = {(uint16_t)x,(uint16_t)y,(uint16_t)z,v};
}
void restore(Grid& g) {
    int m = marks[--nm];
    while (top > m) {
        auto& e = buf[--top];
        g.cell[e.x][e.y][e.z] = e.old_val;
    }
}
```

};

// =============================================================================
// NS QUEUE — FIFO for naked-single propagation
// =============================================================================

struct NSQueue {
int  items[NSQUEUE_CAP];
int  head = 0, tail = 0;
void clear() { head = tail = 0; }
bool empty() const { return head == tail; }
void push(int pos) { items[tail++ & (NSQUEUE_CAP-1)] = pos; }
int  pop()         { return items[head++ & (NSQUEUE_CAP-1)]; }
};

// =============================================================================
// GLOBALS — statistics
// =============================================================================

static long long g_ns     = 0;  // naked singles fired
static long long g_hs     = 0;  // hidden singles fired
static long long g_triads = 0;  // triad eliminations
static long long g_nodes  = 0;  // DFS nodes expanded
static long long g_bt     = 0;  // backtracks

// =============================================================================
// CORE: ELIMINATION WITH TRAIL
// =============================================================================

// Eliminate digit `bit` from cell (x,y,z). Returns false if domain becomes empty.
// Logs to trail if the cell actually changes.
inline bool elim(Grid& g, Trail& tr, NSQueue& q, int x, int y, int z, uint16_t bit) {
uint16_t& c = g.cell[x][y][z];
if (!(c & bit)) return true;          // digit not present → nothing to do
tr.push(x, y, z, c);
c &= ~bit;
if (!c) return false;                 // empty domain → contradiction
if (!(c & (c-1))) q.push(x*N*N + y*N + z);  // became singleton → enqueue NS
return true;
}

// Place digit v in cell (x,y,z): fix cell to {v}, propagate to 6 constraint families.
bool place(Grid& g, Trail& tr, NSQueue& q, int x, int y, int z, int v) {
uint16_t bit = 1 << (v-1);
uint16_t& c  = g.cell[x][y][z];
if (!(c & bit)) return false;

```
// Log the cell itself before changing it
if (c != bit) { tr.push(x, y, z, c); c = bit; }

// Axis-Z line: (x,y,*) minus self
for (int k = 0; k < N; k++)
    if (k != z && !elim(g, tr, q, x, y, k, bit)) return false;
// Axis-Y line: (x,*,z) minus self
for (int k = 0; k < N; k++)
    if (k != y && !elim(g, tr, q, x, k, z, bit)) return false;
// Axis-X line: (*,y,z) minus self
for (int k = 0; k < N; k++)
    if (k != x && !elim(g, tr, q, k, y, z, bit)) return false;

// XY block (z layer): block (x/3, y/3)
{ int bx = x/K, by = y/K;
  for (int dx = 0; dx < K; dx++) for (int dy = 0; dy < K; dy++) {
      int nx = bx*K+dx, ny = by*K+dy;
      if (nx == x && ny == y) continue;
      if (!elim(g, tr, q, nx, ny, z, bit)) return false;
  }}
// XZ block (y layer): block (x/3, z/3)
{ int bx = x/K, bz = z/K;
  for (int dx = 0; dx < K; dx++) for (int dz = 0; dz < K; dz++) {
      int nx = bx*K+dx, nz = bz*K+dz;
      if (nx == x && nz == z) continue;
      if (!elim(g, tr, q, nx, y, nz, bit)) return false;
  }}
// YZ block (x layer): block (y/3, z/3)
{ int by = y/K, bz = z/K;
  for (int dy = 0; dy < K; dy++) for (int dz = 0; dz < K; dz++) {
      int ny = by*K+dy, nz = bz*K+dz;
      if (ny == y && nz == z) continue;
      if (!elim(g, tr, q, x, ny, nz, bit)) return false;
  }}
return true;
