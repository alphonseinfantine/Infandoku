// =============================================================================
// FULL PROPAGATION PASS: NS → HS → Triads (loop until fixpoint)
// =============================================================================

bool propagate(Grid& g, Trail& tr, NSQueue& q) {
// Prime the NS queue with any existing singletons
for (int x = 0; x < N; x++) for (int y = 0; y < N; y++) for (int z = 0; z < N; z++) {
if (!g.cell[x][y][z]) return false;
if (!(g.cell[x][y][z] & (g.cell[x][y][z]-1)))
q.push(x*N*N + y*N + z);
}

```
bool progress = true;
while (progress) {
    progress = false;

    if (!flush_ns(g, tr, q)) return false;

    long long hs_before = g_hs;
    if (!hidden_singles(g, tr, q)) return false;
    if (g_hs > hs_before) { progress = true; if (!flush_ns(g, tr, q)) return false; }

    long long tr_before = g_triads;
    if (!triads_3d(g, tr, q)) return false;
    if (g_triads > tr_before) { progress = true; if (!flush_ns(g, tr, q)) return false; }
}
return true;
```

