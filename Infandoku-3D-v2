static const int N  = 9;          // grid size per axis
static const int K  = 3;          // block size per axis
static const int CELLS = N*N*N;   // 729
static const int FULL = (1<<N)-1; // bitmask 0b111111111 = all 9 digits present

// =============================================================================
// GRID — bit-board representation
// =============================================================================
// cell[x][y][z] = uint16_t bitmask of remaining candidates (bit i-1 = digit i).
// A solved cell has exactly 1 bit set. An empty domain (contradiction) = 0.

struct Grid {
uint16_t cell[N][N][N];

```
void init() {
    for (auto& a : cell) for (auto& b : a) for (auto& c : b) c = FULL;
}

bool solved() const {
    for (auto& a : cell) for (auto& b : a) for (auto& c : b)
        if (__builtin_popcount(c) != 1) return false;
    return true;
}
```

