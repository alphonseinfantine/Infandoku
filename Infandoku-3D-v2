// =============================================================================
// MRV — pick the unsolved cell with the fewest candidates
// =============================================================================

std::tuple<int,int,int> mrv(const Grid& g) {
int bx = -1, by = -1, bz = -1, bmin = N+1;
for (int x = 0; x < N; x++) for (int y = 0; y < N; y++) for (int z = 0; z < N; z++) {
int cnt = __builtin_popcount(g.cell[x][y][z]);
if (cnt == 1) continue;
if (!cnt)     return {-1,-1,-1};  // contradiction
if (cnt < bmin) { bmin = cnt; bx = x; by = y; bz = z; }
}
return {bx, by, bz};
}

// =============================================================================
// SOLVER — DFS with trail-based backtracking
// =============================================================================
// G is modified in-place. Trail allows O(delta) undo.
// Stack frames hold only local variables — no full Grid copy per node.

bool solve(Grid& g, Trail& tr) {
g_nodes++;

```
NSQueue q; q.clear();
if (!propagate(g, tr, q)) return false;

auto [bx, by, bz] = mrv(g);
if (bx < 0) return true;   // all cells are singletons → solved

uint16_t mask = g.cell[bx][by][bz];
while (mask) {
    uint16_t bit = mask & (-mask); mask &= mask-1;
    int v = __builtin_ctz(bit) + 1;

    tr.save();
    { NSQueue qb; qb.clear();
      if (place(g, tr, qb, bx, by, bz, v) && solve(g, tr)) return true;
    }
    tr.restore(g);
    g_bt++;
}
return false;
```

