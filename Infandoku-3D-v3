bool hidden_singles(Grid& g, Trail& tr, NSQueue& q){
bool progress=false;
// Macro for one line of N cells
auto hs_line=[&](int cells[N])->bool{
uint16_t seen=0,twice=0;
for(int i=0;i<N;i++){int cx,cy,cz;unpos(cells[i],cx,cy,cz);
twice|=seen&g.cell[cx][cy][cz];seen|=g.cell[cx][cy][cz];}
if(!seen) return false;
for(uint16_t once=seen&~twice;once;){
uint16_t bit=once&(-once);once&=once-1;
int v=__builtin_ctz(bit)+1;
for(int i=0;i<N;i++){int cx,cy,cz;unpos(cells[i],cx,cy,cz);
if(g.cell[cx][cy][cz]&bit){
if(g.cell[cx][cy][cz]!=bit){
tr.push(cx,cy,cz,g.cell[cx][cy][cz]);
g.cell[cx][cy][cz]=bit;
q.push(cells[i]);
g_mrv.write(cx,cy,cz,1);
g_hs++;progress=true;
}
break;
}
}
}
return true;
};

