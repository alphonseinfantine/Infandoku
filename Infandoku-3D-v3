inline bool elim(Grid& g, Trail& tr, NSQueue& q, int x, int y, int z, uint16_t bit){
uint16_t& c=g.cell[x][y][z];
if(!(c&bit)) return true;
tr.push(x,y,z,c);
c&=~bit;
g_mrv.invalidate(x,y,z);
// CBJ: record conflict level
g_conflict_level[x][y][z]=g_current_level;
if(!c){
// Contradiction — update jump target to max conflict level of this cell’s peers
// (simplified: just use current level - 1)
if(g_jump_target<g_current_level-1) g_jump_target=g_current_level-1;
return false;
}
if(!(c&(c-1))) q.push(x*N*N+y*N+z); // singleton
return true;
}

bool place(Grid& g, Trail& tr, NSQueue& q, int x, int y, int z, int v){
uint16_t bit=1<<(v-1);
