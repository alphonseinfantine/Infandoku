// For each (line, digit): watch[line_id][digit] = {w0, w1} — two cell positions.
// 6 line families × 81 lines × 9 digits = 4374 watcher pairs.
// Line families:
//   0: X-lines  (*,y,z) → line_id = y*N+z       (81 lines)
//   1: Y-lines  (x,*,z) → line_id = x*N+z
//   2: Z-lines  (x,y,*) → line_id = x*N+y
//   3: XY-blk   z-layer, block (bx,by) → line_id = z*K*K + by*K + bx (81)
//   4: XZ-blk   y-layer, block (bx,bz) → line_id = y*K*K + bz*K + bx
//   5: YZ-blk   x-layer, block (by,bz) → line_id = x*K*K + bz*K + by

static const int N_FAMILIES = 6;
static const int LINES_PER_FAMILY = N*N; // 81

// Each watcher: cell position (encoded as pos(x,y,z)) or -1 if no valid watcher
struct WatchPair { int16_t w0, w1; };

// wl[family][line][digit]
static WatchPair g_wl[N_FAMILIES][LINES_PER_FAMILY][N];

// Get the cells in a line
static void get_line_cells(int fam, int lid, int cells[N]){
switch(fam){
case 0: { int y=lid/N,z=lid%N; for(int x=0;x<N;x++) cells[x]=pos(x,y,z); break; }
case 1: { int x=lid/N,z=lid%N; for(int y=0;y<N;y++) cells[y]=pos(x,y,z); break; }
case 2: { int x=lid/N,y=lid%N; for(int z=0;z<N;z++) cells[z]=pos(x,y,z); break; }
case 3: { int z=lid/(K*K),bx=(lid%(K*K))%K,by=(lid%(K*K))/K;
int i=0; for(int dx=0;dx<K;dx++) for(int dy=0;dy<K;dy++) cells[i++]=pos(bx*K+dx,by*K+dy,z); break; }
case 4: { int y=lid/(K*K),bx=(lid%(K*K))%K,bz=(lid%(K*K))/K;
int i=0; for(int dx=0;dx<K;dx++) for(int dz=0;dz<K;dz++) cells[i++]=pos(bx*K+dx,y,bz*K+dz); break; }
case 5: { int x=lid/(K*K),by=(lid%(K*K))%K,bz=(lid%(K*K))/K;
int i=0; for(int dy=0;dy<K;dy++) for(int dz=0;dz<K;dz++) cells[i++]=pos(x,by*K+dy,bz*K+dz); break; }
}
}

// Build watchers: find 2 cells in line that have digit d as candidate
static void init_watchers(const Grid& g){
for(int fam=0;fam<N_FAMILIES;fam++)
for(int lid=0;lid<LINES_PER_FAMILY;lid++)
for(int d=0;d<N;d++){
int cells[N]; get_line_cells(fam,lid,cells);
uint16_t bit=1<<d;
int w0=-1,w1=-1;
for(int i=0;i<N;i++){
int cx,cy,cz; unpos(cells[i],cx,cy,cz);
if(g.cell[cx][cy][cz]&bit){ if(w0<0) w0=cells[i]; else{ w1=cells[i]; break; }}
}
g_wl[fam][lid][d]={int16_t(w0),int16_t(w1)};
}
}

