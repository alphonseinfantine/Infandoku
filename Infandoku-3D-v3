// =============================================================================
// [C] NAKED PAIRS 3D
// =============================================================================
// In any group of 9, if two cells share the same 2-candidate mask,
// eliminate both candidates from all other cells in the group.

bool naked_pairs(Grid& g, Trail& tr, NSQueue& q){
int cells[N];
for(int fam=0;fam<N_FAMILIES;fam++)
for(int lid=0;lid<LINES_PER_FAMILY;lid++){
get_line_cells(fam,lid,cells);
// Collect 2-candidate cells
for(int i=0;i<N;i++){
int cx,cy,cz; unpos(cells[i],cx,cy,cz);
uint16_t ci=g.cell[cx][cy][cz];
if(__builtin_popcount(ci)!=2) continue;
// Find another cell with same mask
for(int j=i+1;j<N;j++){
int dx,dy,dz; unpos(cells[j],dx,dy,dz);
if(g.cell[dx][dy][dz]!=ci) continue;
// Naked pair found: eliminate ci from all other cells
for(int k=0;k<N;k++){
if(k==i||k==j) continue;
int ex,ey,ez; unpos(cells[k],ex,ey,ez);
if(g.cell[ex][ey][ez]&ci){
if(!elim(g,tr,q,ex,ey,ez,ci)) return false;
g_np++;
}
}
}
}
}
return true;
}

