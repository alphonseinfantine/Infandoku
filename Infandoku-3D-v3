struct NSQueue {
int items[NSQUEUE_CAP];
int head=0,tail=0;
void clear(){ head=tail=0; }
bool empty() const { return head==tail; }
void push(int p){ items[tail++&(NSQUEUE_CAP-1)]=p; }
int  pop()      { return items[head++&(NSQUEUE_CAP-1)]; }
};

