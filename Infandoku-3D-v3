bool flush_ns(Grid& g, Trail& tr, NSQueue& q){
while(!q.empty()){
int p=q.pop(); int x,y,z; unpos(p,x,y,z);
uint16_t c=g.cell[x][y][z];
if(!c) return false;
if(c&(c-1)) continue;
g_ns++;
if(!place(g,tr,q,x,y,z,__builtin_ctz(c)+1)) return false;
}
return true;
}

