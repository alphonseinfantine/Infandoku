struct MRVCache {
uint8_t  size[N][N][N];   // cached domain size (popcount)
uint16_t gen[N][N][N];    // generation when cached
uint16_t cur=1;

```
void init(){
    memset(gen,0,sizeof gen);
    for(auto&a:size) for(auto&b:a) for(auto&c:b) c=N;
    cur=1;
}
void bump(){ cur++; if(!cur) cur=1; }
void invalidate(int x,int y,int z){ gen[x][y][z]=0; }
void write(int x,int y,int z,uint8_t v){ size[x][y][z]=v; gen[x][y][z]=cur; }
bool valid(int x,int y,int z) const { return gen[x][y][z]==cur; }
uint8_t get(int x,int y,int z,const Grid&g){
    if(!valid(x,y,z)){ uint8_t v=__builtin_popcount(g.cell[x][y][z]); write(x,y,z,v); return v; }
    return size[x][y][z];
}
