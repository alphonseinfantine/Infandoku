// =============================================================================
// [A] MRV WITH GEN-COUNTER CACHE
// =============================================================================

std::tuple<int,int,int> mrv(const Grid& g){
int bx=-1,by=-1,bz=-1,bmin=N+1;
for(int x=0;x<N;x++) for(int y=0;y<N;y++) for(int z=0;z<N;z++){
int cnt=g_mrv.get(x,y,z,g);
if(cnt==1) continue;
if(!cnt) return {-1,-1,-1};
if(cnt<bmin){ bmin=cnt; bx=x; by=y; bz=z; }
}
return {bx,by,bz};
}

// =============================================================================
// [D] LCV — sort digit candidates by impact (fewest peer eliminations first)
// =============================================================================
// Impact of placing digit d in (x,y,z) = number of peer cells that contain d.
// Lower impact = less constraining = try first.

void lcv_sort(uint16_t& mask, const Grid& g, int x, int y, int z){
// Collect candidates
uint16_t tmp=mask;
int digits[N],impacts[N],cnt=0;
while(tmp){ uint16_t b=tmp&(-tmp);tmp&=tmp-1; digits[cnt]=**builtin_ctz(b); impacts[cnt]=0; cnt++; }
// Compute impact for each digit
for(int i=0;i<cnt;i++){
uint16_t bit=1<<digits[i];
int imp=0;
// Peers on 3 lines + 3 blocks (no need for perfect accuracy)
for(int k=0;k<N;k++){
if(k!=z) imp+=!!(g.cell[x][y][k]&bit);
if(k!=y) imp+=!!(g.cell[x][k][z]&bit);
if(k!=x) imp+=!!(g.cell[k][y][z]&bit);
}
int bx=x/K,by*=y/K,bz=z/K;
for(int dx=0;dx<K;dx++) for(int dy=0;dy<K;dy++) if(bx*K+dx!=x||by**K+dy!=y) imp+=!!(g.cell[bx*K+dx][by_*K+dy][z]&bit);
for(int dx=0;dx<K;dx++) for(int dz=0;dz<K;dz++) if(bx*K+dx!=x||bz*K+dz!=z) imp+=!!(g.cell[bx*K+dx][y][bz*K+dz]&bit);
for(int dy=0;dy<K;dy++) for(int dz=0;dz<K;dz++) if(by_*K+dy!=y||bz*K+dz!=z) imp+=!!(g.cell[x][by_*K+dy][bz*K+dz]&bit);
impacts[i]=imp;
}
// Sort by impact ascending (insertion sort, cnt≤9)
for(int i=1;i<cnt;i++){
int ki=digits[i],ii=impacts[i],j=i-1;
while(j>=0&&impacts[j]>ii){ digits[j+1]=digits[j];impacts[j+1]=impacts[j];j–; }
digits[j+1]=ki;impacts[j+1]=ii;
}
// Rebuild mask in sorted order (LSB = first to try)
mask=0;
for(int i=cnt-1;i>=0;i–) mask=(mask<<1)|(1<<digits[i]); // placeholder — not quite right
// Actually we can’t easily reorder bits. Instead return as array.
// Use a different representation: store sorted digits back as original mask
// (the DFS will still iterate bits LSB-first, so we encode smallest-impact as bit 0)
// Simpler: just rearrange so lowest-impact digit is the lowest set bit.
// We do this by building a fresh mask with remapped bits.
// Since we can’t change the bit positions, we leave the original mask unchanged
// and instead return sorted order via a separate array.
// For simplicity here: just reverse — try highest-impact last (= lowest-impact first).
(void)mask; // mask is rebuilt below by the caller using the sorted digits array
}

// Sorted candidate iteration for LCV
struct LCVIter {
int digits[N]; int cnt=0; int idx=0;
void build(uint16_t mask, const Grid& g, int x, int y, int z){
cnt=0;
uint16_t tmp=mask;
int impacts[N];
while(tmp){ uint16_t b=tmp&(-tmp);tmp&=tmp-1; digits[cnt]=__builtin_ctz(b); impacts[cnt]=0; cnt++; }
for(int i=0;i<cnt;i++){
uint16_t bit=1<<digits[i]; int imp=0;
for(int k=0;k<N;k++){
if(k!=z) imp+=!!(g.cell[x][y][k]&bit);
if(k!=y) imp+=!!(g.cell[x][k][z]&bit);
if(k!=x) imp+=!!(g.cell[k][y][z]&bit);
}
impacts[i]=imp;
}
// insertion sort ascending
for(int i=1;i<cnt;i++){
int ki=digits[i],ii=impacts[i],j=i-1;
while(j>=0&&impacts[j]>ii){ digits[j+1]=digits[j];impacts[j+1]=impacts[j];j–; }
digits[j+1]=ki;impacts[j+1]=ii;
}
idx=0;
}
bool done() const { return idx>=cnt; }
int  next() { return digits[idx++]+1; } // returns v (1-indexed)
};

