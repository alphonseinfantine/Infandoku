struct UndoEntry { uint16_t x,y,z,old_val; };

static const int TRAIL_CAP   = 131072;
static const int MARK_CAP    = 2048;
static const int NSQUEUE_CAP = 16384;

struct Trail {
UndoEntry buf[TRAIL_CAP];
int       marks[MARK_CAP];
int       top=0, nm=0;

```
void save()                             { marks[nm++]=top; }
void push(int x,int y,int z,uint16_t v){ buf[top++]={(uint16_t)x,(uint16_t)y,(uint16_t)z,v}; }
void restore(Grid& g){
    int m=marks[--nm];
    while(top>m){ auto&e=buf[--top]; g.cell[e.x][e.y][e.z]=e.old_val; }
}
int depth() const { return nm; }
