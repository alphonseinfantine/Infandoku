void build() {
    for (int r = 0; r < N; r++) for (int c = 0; c < N; c++) {
        cell_blk[r][c] = (r/NB)*NB + (c/NB);
        cell_pos[r][c] = (r%NB)*NB + (c%NB);
    }
    for (int b = 0; b < NBLK; b++) for (int p = 0; p < N; p++) {
        blk_row[b][p] = (b/NB)*NB + (p/NB);
        blk_col[b][p] = (b%NB)*NB + (p%NB);
    }
}
