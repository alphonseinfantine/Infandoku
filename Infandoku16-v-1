//  PART 3 — NAKED SINGLES
// ════════════════════════════════════════════════════════════════════

int do_ns(State& st) {
bool progress = true;
while (progress) {
progress = false;
if (!st.empty) return -2;
for (int r = 0; r < N; r++) {
for (uint16_t fr = st.rows[r]; fr;) {
int c = ctz(fr); fr &= fr-1;
int cands = st.cv(r, c);
if (!cands)              return r*N + c;
if (!(cands & (cands-1))) {
if (!st.place(r, c, ctz(cands)+1)) return r*N + c;
progress = true;
if (!st.empty) return -2;
fr = st.rows[r];
}
}
}
}
return -1;
}

