bool prop(State& st) {
while (true) {
int before = st.empty;
int r = do_ns(st); if (r == -2) return true; if (r >= 0) return false;
r     = do_hs(st); if (r == -2) return true; if (r >= 0) return false;
if (st.empty == before) return true;
}
}

