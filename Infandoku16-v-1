State sv = st;
for (int tmp = bc; tmp;) {
    int bit = tmp & (-tmp); tmp &= tmp-1;
    st = sv;
    st.place(bi_r, bi_c, ctz(bit)+1);
    if (solve(st)) return true;
}
st = sv;
return false;
