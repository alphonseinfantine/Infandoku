inline int cv(int r, int c) const {
    return (~(prow[r] | pcol[c] | pblk[T.cell_blk[r][c]])) & FULL_VAL;
}

// Place value v (1-based) at (r,c). Returns false on contradiction.
inline bool place(int r, int c, int v) {
    int b  = T.cell_blk[r][c];
    int p  = T.cell_pos[r][c];
    int vb = 1 << (v - 1);
    board[r*N + c] = v;
    empty--;
    prow[r] |= vb;  pcol[c] |= vb;  pblk[b] |= vb;
    rows[r] &= ~(uint16_t)(1 << c);
    cols[c] &= ~(uint16_t)(1 << r);
    blks[b] &= ~(uint16_t)(1 << p);
    // Contradiction check on neighbours
    for (uint16_t fr = rows[r]; fr; fr &= fr-1) {
        int fc = ctz(fr); if (!cv(r, fc)) return false;
    }
    for (uint16_t fc = cols[c]; fc; fc &= fc-1) {
        int fr = ctz(fc); if (!cv(fr, c)) return false;
    }
    for (uint16_t fb = blks[b]; fb; fb &= fb-1) {
        int pp = ctz(fb);
        if (!cv(T.blk_row[b][pp], T.blk_col[b][pp])) return false;
    }
    return true;
}

bool valid() const {
    for (int i = 0; i < N; i++)
        if (prow[i] != FULL_VAL || pcol[i] != FULL_VAL) return false;
    for (int b = 0; b < NBLK; b++)
        if (pblk[b] != FULL_VAL) return false;
    return !empty;
}

// Init from string. Values 1..16 encoded as hex: 1..9, A..G (or a..g)
// 0 or '.' = empty cell. Expects exactly 256 valid chars.
void init(const std::string& s) {
    memset(this, 0, sizeof(*this));
    for (int i = 0; i < N; i++)  rows[i] = cols[i] = FULL_CELL;
    for (int b = 0; b < NBLK; b++) blks[b] = FULL_CELL;
    int j = 0;
    for (char ch : s) {
        if (j >= N2) break;
        int v = -1;
        if (ch >= '1' && ch <= '9') v = ch - '0';
        else if (ch >= 'A' && ch <= 'G') v = ch - 'A' + 10;
        else if (ch >= 'a' && ch <= 'g') v = ch - 'a' + 10;
        else if (ch == '0' || ch == '.') v = 0;
        else continue; // skip separators
        board[j] = v;
        if (v) {
            int r = j/N, cc = j%N, vb = 1 << (v-1);
            int b = T.cell_blk[r][cc], p = T.cell_pos[r][cc];
            prow[r] |= vb; pcol[cc] |= vb; pblk[b] |= vb;
            rows[r] &= ~(uint16_t)(1 << cc);
            cols[cc] &= ~(uint16_t)(1 << r);
            blks[b]  &= ~(uint16_t)(1 << p);
            initial_clues++;
        } else empty++;
        j++;
    }
}

// Fix the first 4x4 block to 1..16 (canonical form for counting)
// Returns false if contradiction.
bool fix_first_block() {
    for (int p = 0; p < N; p++) {
        int r = T.blk_row[0][p];
        int c = T.blk_col[0][p];
        if (!place(r, c, p+1)) return false;
    }
    return true;
}
